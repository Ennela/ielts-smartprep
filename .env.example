# ===== SPRING PROFILE =====
# Activate a profile: dev | prod
SPRING_PROFILES_ACTIVE=dev

# ===== DATABASE =====
MYSQL_ROOT_PASSWORD=smartprep_root_2024
MYSQL_DATABASE=ielts_smartprep
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/ielts_smartprep
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=smartprep_root_2024

# ===== JWT (REQUIRED — app will NOT start without this) =====
# Generate a strong random secret (min 32 characters / 256 bits):
#   openssl rand -base64 48
JWT_SECRET=

# ===== GOOGLE GEMINI AI =====
GEMINI_API_KEY=your-api-key-from-aistudio-google-com

# ===== FRONTEND =====
VITE_API_URL=http://localhost:8080/api/v1
FRONTEND_URL=http://localhost:5173

# ===== MINIO (S3-compatible Storage) =====
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=listening-audio

# ===== EDGE TTS =====
TTS_ENABLED=true
EDGE_TTS_URL=http://localhost:8000

# ===== MAIL (Gmail App Password) =====
# Create an App Password at https://myaccount.google.com/apppasswords
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=your-16-char-app-password

# ===== SENTRY (Error Tracking — Free Tier) =====
# Get your DSN from https://sentry.io → Project Settings → Client Keys
SENTRY_DSN=
VITE_SENTRY_DSN=
